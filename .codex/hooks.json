{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/sh \"$(git rev-parse --show-toplevel)/.codex/hooks/post-edit-lint.sh\"",
            "statusMessage": "Linting"
          },
          {
            "type": "command",
            "command": "/bin/sh \"$(git rev-parse --show-toplevel)/.codex/hooks/docsync-check.sh\"",
            "statusMessage": "Checking doc sync"
          }
        ]
      }
    ]
  }
}
